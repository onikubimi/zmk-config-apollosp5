#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/mouse.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };

    physical_layout0: physical_layout0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
keys 
            /* Row 0: 1段目 (10個) */
            = <&key_physical_attrs 100 100 100 25 0 0 0>   // [0,1]
            , <&key_physical_attrs 100 100 200 0 0 0 0>    // [0,2]
            , <&key_physical_attrs 100 100 300 -25 0 0 0>  // [0,3]
            , <&key_physical_attrs 100 100 400 0 0 0 0>    // [0,4]
            , <&key_physical_attrs 100 100 500 25 0 0 0>   // [0,5]

            , <&key_physical_attrs 100 100 850 25 0 0 0>   // [0,8]
            , <&key_physical_attrs 100 100 950 0 0 0 0>    // [0,9]
            , <&key_physical_attrs 100 100 1050 -25 0 0 0> // [0,10]
            , <&key_physical_attrs 100 100 1150 0 0 0 0>   // [0,11]
            , <&key_physical_attrs 100 100 1250 25 0 0 0>  // [0,12]

            /* Row 1: 2段目 (14個) */
            , <&key_physical_attrs 100 100 0 100 0 0 0>     // [1,0]
            , <&key_physical_attrs 100 100 100 125 0 0 0>   // [1,1]
            , <&key_physical_attrs 100 100 200 100 0 0 0>   // [1,2]
            , <&key_physical_attrs 100 100 300 75 0 0 0>    // [1,3]
            , <&key_physical_attrs 100 100 400 100 0 0 0>   // [1,4]
            , <&key_physical_attrs 100 100 500 125 0 0 0>   // [1,5]
            , <&key_physical_attrs 100 100 625 125 0 0 0>   // [1,6]

            , <&key_physical_attrs 100 100 725 125 0 0 0>   // [1,7]
            , <&key_physical_attrs 100 100 850 125 0 0 0>   // [1,8]
            , <&key_physical_attrs 100 100 950 100 0 0 0>   // [1,9]
            , <&key_physical_attrs 100 100 1050 75 0 0 0>   // [1,10]
            , <&key_physical_attrs 100 100 1150 100 0 0 0>  // [1,11]
            , <&key_physical_attrs 100 100 1250 125 0 0 0>  // [1,12]
            , <&key_physical_attrs 100 100 1350 100 0 0 0>  // [1,13]

            /* Row 2: 3段目 (14個) */
            , <&key_physical_attrs 100 100 0 200 0 0 0>     // [2,0]
            , <&key_physical_attrs 100 100 100 225 0 0 0>   // [2,1]
            , <&key_physical_attrs 100 100 200 200 0 0 0>   // [2,2]
            , <&key_physical_attrs 100 100 300 175 0 0 0>   // [2,3]
            , <&key_physical_attrs 100 100 400 200 0 0 0>   // [2,4]
            , <&key_physical_attrs 100 100 500 225 0 0 0>   // [2,5]
            , <&key_physical_attrs 100 100 625 225 0 0 0>   // [2,6]

            , <&key_physical_attrs 100 100 725 225 0 0 0>   // [2,7]
            , <&key_physical_attrs 100 100 850 225 0 0 0>   // [2,8]
            , <&key_physical_attrs 100 100 950 200 0 0 0>   // [2,9]
            , <&key_physical_attrs 100 100 1050 175 0 0 0>  // [2,10]
            , <&key_physical_attrs 100 100 1150 200 0 0 0>  // [2,11]
            , <&key_physical_attrs 100 100 1250 225 0 0 0>  // [2,12]
            , <&key_physical_attrs 100 100 1350 200 0 0 0>  // [2,13]

            /* Row 3: 4段目 (12個) */
            , <&key_physical_attrs 100 100 0 300 0 0 0>     // [3,0]
            , <&key_physical_attrs 100 100 100 325 0 0 0>   // [3,1]
            , <&key_physical_attrs 100 100 200 300 0 0 0>   // [3,2]
            , <&key_physical_attrs 100 100 300 275 0 0 0>   // [3,3]
            , <&key_physical_attrs 100 100 400 300 0 0 0>   // [3,4]
            , <&key_physical_attrs 100 100 500 325 0 0 0>   // [3,5]

            , <&key_physical_attrs 100 100 850 325 0 0 0>   // [3,8]
            , <&key_physical_attrs 100 100 950 300 0 0 0>   // [3,9]
            , <&key_physical_attrs 100 100 1050 275 0 0 0>  // [3,10]
            , <&key_physical_attrs 100 100 1150 300 0 0 0>  // [3,11]
            , <&key_physical_attrs 100 100 1250 325 0 0 0>  // [3,12]
            , <&key_physical_attrs 100 100 1350 300 0 0 0>  // [3,13]

            /* Row 4: 親指 (8個) */
            , <&key_physical_attrs 100 100 295 370 0 0 0>   // [4,3]
            , <&key_physical_attrs 100 100 485 400 10 0 0>  // [4,4]
            , <&key_physical_attrs 100 100 660 410 20 0 0>  // [4,5]
            , <&key_physical_attrs 100 100 810 420 30 0 0>  // [4,6]

            , <&key_physical_attrs 100 100 425 450 -30 0 0> // [4,7]
            , <&key_physical_attrs 100 100 690 410 -20 0 0> // [4,8]
            , <&key_physical_attrs 100 100 935 430 -10 0 0> // [4,9]
            , <&key_physical_attrs 100 100 1150 400 0 0 0>; // [4,10]
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <5>;
        map = <
            RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                     RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)     RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)     RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                     RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
                                    RC(4,3) RC(4,4) RC(4,5) RC(4,6)     RC(4,7) RC(4,8) RC(4,9) RC(4,10)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
        row-gpios
            = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
            , <&gpio0 2  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        b-gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        steps = <24>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <20>;
    };
};
